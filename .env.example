# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# OpenAI API Key
OPENAI_API_KEY=sk-your_openai_api_key_here

# OpenAI Base URL (default: https://routerai.ru/api/v1)
OPENAI_BASE_URL=https://routerai.ru/api/v1

# OpenAI model
OPENAI_MODEL=openai/gpt-5.4-nano

# Server port (default: 3000)
PORT=3000

# Environment: development | production
NODE_ENV=development

# Owner gets permanent free Premium access.
# In development, user 12345 is treated as owner if this is empty.
OWNER_TELEGRAM_ID=

# Comma-separated Telegram IDs allowed to grant/revoke free access.
ADMIN_TELEGRAM_IDS=
