# Production environment variables
# Copy this file to .env and fill in the values

# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# OpenAI API Key
OPENAI_API_KEY=sk-your_openai_api_key_here

# OpenAI Base URL (default: https://routerai.ru/api/v1)
OPENAI_BASE_URL=https://routerai.ru/api/v1

# OpenAI model
OPENAI_MODEL=openai/gpt-5.4-nano

# Server port
PORT=3000

# Environment: production
NODE_ENV=production

# Owner gets permanent free Premium access
OWNER_TELEGRAM_ID=

# Comma-separated Telegram IDs allowed to grant/revoke free access
ADMIN_TELEGRAM_IDS=
